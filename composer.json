{
    "name": "webpatser/laravel-countries",
    "description": "Modern Laravel Countries package providing ISO 3166-2, ISO 3166-3, currency, capital and more for all countries. Compatible with Laravel 11.x, 12.x, and 13.x.",
    "authors": [
        {
            "name": "Christoph Kempen",
            "email": "christoph@downsized.nl",
            "homepage": "https://downsized.nl/",
            "role": "developer"
        },
        {
            "name": "Paul Kievits",
            "role": "developer"
        }
    ],
    "keywords": [
        "laravel",
        "countries",
        "iso_3166_2",
        "iso_3166_3",
        "currency",
        "capitals"
    ],
    "homepage": "https://github.com/webpatser/laravel-countries",
    "license": [
        "MIT"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Webpatser\\Countries\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "support": {
        "source": "https://github.com/webpatser/laravel-countries",
        "issues": "https://github.com/webpatser/laravel-countries/issues"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webpatser\\Countries\\CountriesServiceProvider"
            ],
            "aliases": {
                "Countries": "Webpatser\\Countries\\CountriesFacade"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
